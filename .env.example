# Anahuac RV Park — Environment Variables
# Copy this file to .env and fill in your values.

# --- Server ---
PORT=3000
APP_URL=https://your-app-url.up.railway.app
NODE_ENV=production
JWT_SECRET=your-jwt-secret-here
ALLOWED_ORIGINS=https://your-app-url.up.railway.app

# --- Database ---
# Railway: uses RAILWAY_VOLUME_MOUNT_PATH automatically
# Local: set a custom path or leave blank for default ./data/rvpark.db
DB_PATH=./data/rvpark.db

# --- Admin ---
DEFAULT_ADMIN_PASSWORD=changeme123
DEFAULT_RECOVERY_PIN=0000

# --- Twilio (SMS) ---
# A2P 10DLC registration required for US SMS delivery
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- Resend (Email) ---
# Sign up at resend.com — free tier: 100 emails/day
RESEND_API_KEY=

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI (optional — expense categorization) ---
ANTHROPIC_API_KEY=
